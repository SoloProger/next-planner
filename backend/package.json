{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node index.js",
    "dev": "nodemon --watch src src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --ignore-path .gitignore --write \"./src/**/*.+(js|ts|json)\"",
    "prettier:fix": "prettier --write src",
    "typeorm": "typeorm-ts-node-commonjs",
    "entity": "npx typeorm-ts-node-commonjs entity:create ./src/database/entities/${ENT_NAME}",
    "mig:add": "npx typeorm-ts-node-commonjs migration:create ./src/database/migrations/${MIG_NAME}",
    "mig:gen": "npx typeorm-ts-node-commonjs migration:generate ./src/database/migrations/${MIG_NAME} -d ./src/data-source.ts",
    "mig:run": "npx typeorm-ts-node-commonjs migration:run -d ./src/data-source.ts",
    "mig:back": "npx typeorm-ts-node-commonjs migration:revert -d ./src/data-source.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.1",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
